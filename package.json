{
  "name": "nolan-young-local-agent-laboratory-lmstudio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25",
    "npm": ">=11.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "validate": "npm run verify:workspaces && npm run verify:github-operations && npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build",
    "validate:ci": "npm run validate",
    "clean": "tsx scripts/clean-generated-data.ts",
    "agent-definition-auditor": "tsx agents/agent-definition-auditor/run.ts",
    "github-repo-review": "tsx agents/github-repo-review/run.ts",
    "github-issue-agent": "tsx agents/github-issue-agent/run.ts",
    "wordpress-blog-writer-agent": "tsx agents/wordpress-blog-writer-agent/run.ts",
    "wordpress-homepage-template-composer-agent": "tsx agents/wordpress-homepage-template-composer-agent/run.ts",
    "wordpress-theme-file-reviewer-agent": "tsx agents/wordpress-theme-file-reviewer-agent/run.ts",
    "wordpress-theme-verification-agent": "tsx agents/wordpress-theme-verification-agent/run.ts",
    "check:lmstudio": "tsx scripts/check-lmstudio.ts",
    "verify:workspaces": "tsx scripts/verify-workspaces.ts",
    "verify:github-operations": "tsx scripts/verify-github-operations.ts"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^24.0.0",
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^3.3.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "dotenv": "^17.2.0",
    "eslint": "^9.31.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "exceljs": "^4.4.0"
  }
}
