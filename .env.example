LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
# `auto` uses exactly one model already loaded on the connected LM Studio server.
# Set an exact model key here (for example, openai/gpt-oss-20b) to pin a model.
LMSTUDIO_MODEL=auto
# LMSTUDIO_API_TOKEN=only-if-enabled-in-LM-Studio
LM_STUDIO_API_TOKEN=

# Reserved for a future publisher workflow; the blog writer never sends email.
RESEND_API_KEY=
BLOG_EMAIL_SENDER=

MODEL_TEMPERATURE=0.1
MODEL_CONTEXT_TOKENS=32768
MODEL_MAX_OUTPUT_TOKENS=4096
MODEL_CONNECTION_TIMEOUT_MS=15000
MODEL_RESOLUTION_TIMEOUT_MS=60000
MODEL_LOAD_TIMEOUT_MS=300000
MODEL_REQUEST_TIMEOUT_MS=300000
MODEL_MAX_RETRIES=2
MODEL_RETRY_DELAY_MS=2000

DEFAULT_MAX_AGENT_STEPS=20
DEFAULT_MAX_REPAIR_PASSES=3
REPORTS_DIRECTORY=reports/runs
