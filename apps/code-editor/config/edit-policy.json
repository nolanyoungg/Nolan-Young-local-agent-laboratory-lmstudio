{
  "version": 1,
  "readAllow": [".", "**", "**/*"],
  "writeAllow": ["**", "**/*"],
  "deny": [
    ".git/**",
    ".env",
    ".env.*",
    "node_modules/**",
    "reports/**",
    "**/*.pem",
    "**/*.key",
    "**/id_rsa*",
    "**/credentials*"
  ],
  "maximumFileBytes": 1048576,
  "maximumOutputBytes": 131072,
  "maximumFiles": 2000,
  "maximumSearchMatches": 200
}
