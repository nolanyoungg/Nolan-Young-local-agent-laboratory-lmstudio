{
  "include": ["package.json", "README.md", "LICENSE", "dist/**", "src/**"],
  "exclude": [
    ".git",
    ".git/**",
    "**/.git/**",
    ".env*",
    "**/.env*",
    "node_modules/**",
    "**/node_modules/**",
    "reports/**",
    "**/reports/**",
    "coverage/**",
    "**/coverage/**",
    ".cache/**",
    "**/.cache/**",
    ".npm/**",
    "**/.npm/**",
    ".pnpm-store/**",
    "**/.pnpm-store/**",
    ".yarn/cache/**",
    "**/.yarn/cache/**",
    ".ssh/**",
    "**/.ssh/**",
    "**/*.{zip,tgz,tar,sha256}",
    "**/*.{pem,key,p12,pfx,crt,cer,der}",
    "**/id_{rsa,dsa,ecdsa,ed25519}",
    "**/credentials",
    "**/credentials.*",
    "**/.credentials*",
    "**/secrets.*",
    "**/.secrets.*",
    "**/service-account*.json"
  ],
  "maximumEntries": 10000,
  "maximumArchiveBytes": 1073741824
}
