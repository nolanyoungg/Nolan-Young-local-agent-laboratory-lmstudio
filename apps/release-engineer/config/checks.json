{
  "requiredPackageFields": ["name", "version"],
  "requiredFiles": ["package.json", "README.md", "LICENSE"],
  "forbiddenGlobs": [
    ".git",
    ".git/**",
    "**/.git",
    "**/.git/**",
    ".env*",
    "**/.env*",
    "node_modules",
    "node_modules/**",
    "**/node_modules",
    "**/node_modules/**",
    "reports",
    "reports/**",
    "**/reports/**",
    "coverage",
    "coverage/**",
    "**/coverage/**",
    ".cache",
    ".cache/**",
    "**/.cache/**",
    ".npm",
    ".npm/**",
    "**/.npm/**",
    ".pnpm-store",
    ".pnpm-store/**",
    "**/.pnpm-store/**",
    ".yarn/cache/**",
    "**/.yarn/cache/**",
    ".ssh",
    ".ssh/**",
    "**/.ssh/**",
    "**/*.{pem,key,p12,pfx,crt,cer,der}",
    "**/id_{rsa,dsa,ecdsa,ed25519}",
    "**/credentials",
    "**/credentials.*",
    "**/.credentials*",
    "**/secrets.*",
    "**/.secrets.*",
    "**/service-account*.json"
  ]
}
