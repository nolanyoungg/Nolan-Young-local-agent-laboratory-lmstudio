{
  "name": "@local-agent-lab/release-engineer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "local-release-engineer": "./dist/src/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "prompts",
    "config",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx src/cli.ts",
    "start": "node dist/src/cli.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@local-agent-lab/agent-runtime": "*",
    "@local-agent-lab/filesystem-tools": "*",
    "@local-agent-lab/local-model-client": "*",
    "@local-agent-lab/shared-types": "*",
    "@local-agent-lab/tracing": "*",
    "@local-agent-lab/workspace-security": "*",
    "dotenv": "^17.2.0",
    "minimatch": "^10.0.3",
    "yauzl": "^3.2.0",
    "yazl": "^3.3.1",
    "zod": "^3.25.76"
  }
}
