{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist-scripts",
    "tsBuildInfoFile": "dist-scripts/.tsbuildinfo"
  },
  "include": ["scripts/**/*.ts", "agents/**/*.ts"],
  "references": [
    { "path": "packages/shared-types" },
    { "path": "packages/workspace-security" },
    { "path": "packages/filesystem-tools" },
    { "path": "packages/tracing" },
    { "path": "packages/local-model-client" },
    { "path": "packages/agent-runtime" }
  ]
}
